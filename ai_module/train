# Кэш для предсказаний
class PredictionCache:  
    def __init__(self, max_size: int = 1000):
        self.cache = {}
        self.max_size = max_size
        self.hits = 0
        self.misses = 0
    
    def get(self, key: str) -> Optional[Tuple[str, float]]:
        if key in self.cache:
            self.hits += 1
            return self.cache[key]
        self.misses += 1
        return None
    
    def set(self, key: str, value: Tuple[str, float]):
        if len(self.cache) >= self.max_size:
            oldest_key = next(iter(self.cache))
            del self.cache[oldest_key]
        self.cache[key] = value
    
    def get_stats(self) -> Dict:
        total = self.hits + self.misses
        hit_rate = self.hits / total if total > 0 else 0
        return {'hits': self.hits, 'misses': self.misses, 'hit_rate': hit_rate}


# Классификатор пользовательских намерений для запросов, связанных с зоомагазином
# Используем в работе рекуррентную нейронную сеть (RNN) с слоями LSTM
class PetStoreIntentClassifier:

    # Инициализация классификатора  
    def __init__(self, config = None):
        if config is None:            
            self.config = Config()    
        else:                         
            self.config = config

        self.vocab_size = config.VOCAB_SIZE
        self.max_sequence_length = config.MAX_SEQUENCE_LENGTH
        self.embedding_size = config.EMBEDDING_SIZE
        self.batch_size = config.BATCH_SIZE
        self.epochs = config.EPOCHS
        self.validation_split = config.VALIDATION_SPLIT

        
        # Инициализация компонентов предобработки текста и меток
        self.tokenizer = Tokenizer(num_words=self.vocab_size, oov_token="<OOV>",
                                   filters='!"#$%&()*+,-./:;<=>?@[\\]^_`{|}~\t\n') # Добавлен filters
        self.label_encoder = LabelEncoder()
        self.model = None
        self.training_history = None # Пока нет истории

        # Кэш
        self.cache = PredictionCache(max_size=self.config.CACHE_SIZE) if self.config.USE_CACHE else None
        self.embedding_matrix = None
        if self.config.USE_PRETRAINED_EMBEDDINGS and FASTTEXT_AVAILABLE:
            self._load_pretrained_embeddings()
    
    def _load_pretrained_embeddings(self):
        try:
            ft = fasttext.load_model(self.config.PRETRAINED_EMBEDDINGS_PATH)
            logger.info(f"Загружены предобученные эмбеддинги")
        except Exception as e:
            logger.error(f"Ошибка загрузки эмбеддингов: {e}")
            self.config.USE_PRETRAINED_EMBEDDINGS = False
    
    def _create_embedding_matrix(self, word_index: Dict) -> np.ndarray:
        if not self.config.USE_PRETRAINED_EMBEDDINGS or not FASTTEXT_AVAILABLE:
            return None
        
        embedding_matrix = np.zeros((self.vocab_size, self.embedding_size))
        ft = fasttext.load_model(self.config.PRETRAINED_EMBEDDINGS_PATH)
        
        for word, i in word_index.items():
            if i < self.vocab_size:
                try:
                    embedding_matrix[i] = ft.get_word_vector(word)
                except:
                    embedding_matrix[i] = np.random.normal(size=(self.embedding_size,))
        
        return embedding_matrix
        
    def _preprocess_text(self, text: str) -> str:  
        # Приведение к нижнему регистру
        text = text.lower()
    
        # Удаление лишних пробелов
        text = re.sub(r'\s+', ' ', text).strip()
    
        # Удаление эмодзи и спецсимволов
        text = re.sub(r'[^\w\s]', ' ', text)
    
        # Удаление стоп-слов 
        if self.config.USE_LEMMATIZATION and LEMMATIZATION_AVAILABLE:
            words = text.split()
            lemmatized_words = []
            for word in words:
                try:
                    lemmatized = MORPH.parse(word)[0].normal_form
                    lemmatized_words.append(lemmatized)
                except:
                    lemmatized_words.append(word)
            text = ' '.join(lemmatized_words)

        if self.config.USE_STOP_WORDS:
            words = text.split()
            words = [w for w in words if w not in RUSSIAN_STOP_WORDS]
            text = ' '.join(words)
    
        return text

    def _augment_text(self, text: str) -> List[str]:  
        if not self.config.USE_DATA_AUGMENTATION:
            return [text]
    
        augmented = [text]
        words = text.split()
    
        # Замена синонимов
        for i, word in enumerate(words):
            if word in SYNONYMS and random.random() < self.config.AUGMENTATION_PROBABILITY:
                new_word = random.choice(SYNONYMS[word])
                new_text = ' '.join(words[:i] + [new_word] + words[i+1:])
                augmented.append(new_text)

        if len(words) >= 3 and random.random() < 0.3:
            shuffled = words.copy()
            random.shuffle(shuffled)
            augmented.append(' '.join(shuffled))
        
        if len(words) >= 4 and random.random() < 0.2:
            remove_idx = random.randint(0, len(words)-1)
            shortened = words[:remove_idx] + words[remove_idx+1:]
            augmented.append(' '.join(shortened))
        
        return list(set(augmented))
    

    # Подготовим данные для обучения: токенизация и кодирование меток   
    def prepare_data(self, texts: List[str], labels: List[str], augment: bool = True) -> Tuple[np.ndarray, np.ndarray]:
        processed_texts = []
        processed_labels = []
        
        for text, label in zip(texts, labels):
        # Предобработка
        clean_text = self._preprocess_text(text) 
        processed_texts.append(clean_text)
        processed_labels.append(label)

        # Аугментация 
        if augment and self.config.USE_DATA_AUGMENTATION:
            augmented_texts = self._augment_text(clean_text)
            for aug_text in augmented_texts[1:]:
                processed_texts.append(aug_text)
                processed_labels.append(label)
                   
        self.tokenizer.fit_on_texts(processed_texts)

        sequences = self.tokenizer.texts_to_sequences(processed_texts)
        X = pad_sequences(sequences, maxlen=self.max_sequence_length, padding='post', truncating='post')
        
        # Кодирование меток в числа
        y = self.label_encoder.fit_transform(processed_labels)

        if self.config.USE_PRETRAINED_EMBEDDINGS and FASTTEXT_AVAILABLE:
            self.embedding_matrix = self._create_embedding_matrix(self.tokenizer.word_index)

        logger.info(f"Подготовлено {len(processed_texts)} примеров")
        return X, y
    
    # Создадим архитектуры нейросети
    def build_model(self) -> tf.keras.Model:
        inputs = tf.keras.Input(shape=(self.max_sequence_length,)) 

        if self.embedding_matrix is not None:
            # Embedding слой
            embedding = layers.Embedding(
                self.vocab_size, self.embedding_size,
                weights=[self.embedding_matrix],
                trainable=True,
                input_length=self.max_sequence_length
            )(inputs)
       else:
            embedding = layers.Embedding(
                self.vocab_size, self.embedding_size,
                input_length=self.max_sequence_length,
                mask_zero=True
            )(inputs)
    
        embedding = layers.SpatialDropout1D(0.2)(embedding)
    
        # Выбор типа RNN 
        if self.config.USE_GRU:
            lstm_out = layers.Bidirectional(
                layers.GRU(64, return_sequences=True, dropout=self.config.DROPOUT_RATE,
                      recurrent_dropout=self.config.RECURRENT_DROPOUT)
            )(embedding)
        else:
            lstm_out = layers.Bidirectional(
                layers.LSTM(64, return_sequences=True, dropout=self.config.DROPOUT_RATE,
                       recurrent_dropout=self.config.RECURRENT_DROPOUT)
            )(embedding)
    
        lstm_out = layers.Dropout(self.config.DROPOUT_RATE)(lstm_out)
    
        # Механизм внимания 
        if self.config.USE_ATTENTION:
            lstm_out = layers.GlobalMaxPooling1D()(lstm_out)
            lstm_out = layers.Dense(64, activation='tanh')(lstm_out)
        else:
            lstm_out = layers.GlobalMaxPooling1D()(lstm_out)

        # Batch Normalization 
        lstm_out = layers.BatchNormalization()(lstm_out)
           
        # Полносвязные слои с L2 регуляризацией
        dense1 = layers.Dense(128, activation='relu',
                         kernel_regularizer=tf.keras.regularizers.l2(self.config.L2_REGULARIZATION))(lstm_out)
        dense1 = layers.BatchNormalization()(dense1)
        dense1 = layers.Dropout(self.config.DROPOUT_RATE)(dense1)
    
        dense2 = layers.Dense(64, activation='relu',
                         kernel_regularizer=tf.keras.regularizers.l2(self.config.L2_REGULARIZATION))(dense1)
        dense2 = layers.BatchNormalization()(dense2)
        dense2 = layers.Dropout(self.config.DROPOUT_RATE * 0.5)(dense2)
    
        outputs = layers.Dense(len(INTENTS), activation='softmax')(dense2)
    
        model = tf.keras.Model(inputs=inputs, outputs=outputs)

        # Оптимизатор с gradient clipping
        optimizer = tf.keras.optimizers.Adam(learning_rate=self.config.INITIAL_LEARNING_RATE,
                                        clipnorm=self.config.GRADIENT_CLIP_NORM)
        
        model.compile(optimizer=optimizer, loss='sparse_categorical_crossentropy', metrics=['accuracy'])
    
        self.model = model
        logger.info("Модель успешно построена")
        return model
    
    # Обучим модель
    def train(self, X: np.ndarray, y: np.ndarray, X_val: np.ndarray = None, y_val: np.ndarray = None) -> tf.keras.callbacks.History:
        # Если модель еще не создана, создаем
        if self.model is None:
            self.build_model()

        callbacks_list = []

        # Настройка callback для ранней остановки обучения
        early_stop = tf.keras.callbacks.EarlyStopping(
            monitor='val_loss' if X_val is not None else 'loss',
            patience=5,
            restore_best_weights=True
            verbose=1
        )
        callbacks_list.append(early_stop)

        # Learning rate scheduling 
        if self.config.USE_LEARNING_RATE_SCHEDULING:
            reduce_lr = tf.keras.callbacks.ReduceLROnPlateau(
                monitor='val_loss' if X_val is not None else 'loss',
                factor=self.config.REDUCE_LR_FACTOR,
                patience=self.config.REDUCE_LR_PATIENCE,
                min_lr=1e-6,
                verbose=1
            )
            callbacks_list.append(reduce_lr)
            
        # Model checkpoint (Сохраняет лучшую модель)
        checkpoint = tf.keras.callbacks.ModelCheckpoint(
            'best_model.h5',
            monitor='val_accuracy' if X_val is not None else 'accuracy',
            save_best_only=True,
            mode='max',
            verbose=1
        )
        callbacks_list.append(checkpoint)

        # TensorBoard 
        log_dir = f"logs/fit/{datetime.now().strftime('%Y%m%d-%H%M%S')}"
        tensorboard = tf.keras.callbacks.TensorBoard(log_dir=log_dir, histogram_freq=0)
        callbacks_list.append(tensorboard)
    
        validation_data = (X_val, y_val) if X_val is not None else None
    
        self.training_history = self.model.fit(
            X, y,
            epochs=self.epochs,
            batch_size=self.batch_size,
            validation_data=validation_data,
            validation_split=self.validation_split if X_val is None else 0,
            callbacks=callbacks_list,
            verbose=1
        )
        
        return self.training_history

    def train_with_cross_validation(self, X: np.ndarray, y: np.ndarray, 
                                   n_folds: int = 3) -> Dict[str, float]:
        skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=42)
        cv_scores = []
        
        for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):
            logger.info(f"Fold {fold + 1}/{n_folds}")
            
            X_train_fold, X_val_fold = X[train_idx], X[val_idx]
            y_train_fold, y_val_fold = y[train_idx], y[val_idx]
            
            self.model = None
            self.build_model()
            
            self.train(X_train_fold, y_train_fold, X_val_fold, y_val_fold)
            
            results = self.model.evaluate(X_val_fold, y_val_fold, verbose=0)
            cv_scores.append(results[1])
        
        return {
            'mean_accuracy': np.mean(cv_scores),
            'std_accuracy': np.std(cv_scores),
            'fold_scores': cv_scores
        }
    
    def predict(self, text: str, use_cache: bool = True) -> Tuple[str, float]:
        clean_text = self._preprocess_text(text)
        
        if use_cache and self.cache is not None:
            cached = self.cache.get(clean_text)
            if cached is not None:
                return cached
        
        sequence = self.tokenizer.texts_to_sequences([clean_text])
        X_input = pad_sequences(sequence, maxlen=self.max_sequence_length,
                               padding='post', truncating='post')
        
        predictions = self.model.predict(X_input, verbose=0)[0]
        pred_class = np.argmax(predictions)
        confidence = predictions[pred_class]
        
        intent = self.label_encoder.inverse_transform([pred_class])[0]
        
        if use_cache and self.cache is not None:
            self.cache.set(clean_text, (intent, float(confidence)))
        
        return intent, float(confidence)
    
    def predict_batch(self, texts: List[str]) -> List[Tuple[str, float]]:
        clean_texts = [self._preprocess_text(t) for t in texts]
        sequences = self.tokenizer.texts_to_sequences(clean_texts)
        X_input = pad_sequences(sequences, maxlen=self.max_sequence_length,
                               padding='post', truncating='post')
        
        all_predictions = self.model.predict(X_input, verbose=0)
        results = []
        
        for i, predictions in enumerate(all_predictions):
            pred_class = np.argmax(predictions)
            confidence = predictions[pred_class]
            intent = self.label_encoder.inverse_transform([pred_class])[0]
            results.append((intent, float(confidence)))
        
        return results
    
    def predict_with_confidence_threshold(self, text: str, threshold: float = 0.6) -> Tuple[str, float, bool]:
        intent, confidence = self.predict(text)
        is_confident = confidence >= threshold
        return intent, confidence, is_confident
    
    def calculate_detailed_metrics(self, X_test: np.ndarray, y_test: np.ndarray) -> Dict[str, Any]:
        y_pred_proba = self.model.predict(X_test, verbose=0)
        y_pred = np.argmax(y_pred_proba, axis=1)
        
        metrics = {
            'precision_weighted': precision_score(y_test, y_pred, average='weighted', zero_division=0),
            'recall_weighted': recall_score(y_test, y_pred, average='weighted', zero_division=0),
            'f1_weighted': f1_score(y_test, y_pred, average='weighted', zero_division=0),
            'precision_macro': precision_score(y_test, y_pred, average='macro', zero_division=0),
            'recall_macro': recall_score(y_test, y_pred, average='macro', zero_division=0),
            'f1_macro': f1_score(y_test, y_pred, average='macro', zero_division=0),
            'precision_micro': precision_score(y_test, y_pred, average='micro', zero_division=0),
            'recall_micro': recall_score(y_test, y_pred, average='micro', zero_division=0),
            'f1_micro': f1_score(y_test, y_pred, average='micro', zero_division=0)
        }
        
        return metrics
    
    def evaluate_model(self, X_test: np.ndarray, y_test: np.ndarray) -> Dict[str, Any]:
        # Получаем базовые метрики 
        eval_results = self.model.evaluate(X_test, y_test, verbose=0)
        loss = eval_results[0]
        accuracy = eval_results[1]
        
        detailed_metrics = self.calculate_detailed_metrics(X_test, y_test)
        
        y_pred_proba = self.model.predict(X_test, verbose=0)
        y_pred = np.argmax(y_pred_proba, axis=1)
        
        # Получаем только существующие классы
        from sklearn.utils.multiclass import unique_labels
        present_labels = unique_labels(y_test, y_pred)
        present_names = [self.label_encoder.inverse_transform([l])[0] for l in present_labels]
    
        report = classification_report(y_test, y_pred, 
                                 labels=present_labels,
                                 target_names=present_names,
                                 output_dict=True,
                                 zero_division=0)
        
        cm = confusion_matrix(y_test, y_pred)
        
        y_test_one_hot = tf.keras.utils.to_categorical(y_test, num_classes=len(INTENTS))
        roc_auc_scores = {}
        
        for i in range(len(INTENTS)):
            try:
                if len(np.unique(y_test_one_hot[:, i])) > 1:
                    fpr, tpr, _ = roc_curve(y_test_one_hot[:, i], y_pred_proba[:, i])
                    roc_auc = auc(fpr, tpr)
                    roc_auc_scores[INTENTS[i]] = roc_auc
                else:
                    roc_auc_scores[INTENTS[i]] = 0.5
            except:
                roc_auc_scores[INTENTS[i]] = 0.5
        
        results = {
            'loss': float(loss),
            'accuracy': float(accuracy),
            'detailed_metrics': detailed_metrics,
            'classification_report': report,
            'confusion_matrix': cm,
            'roc_auc_scores': roc_auc_scores
        }
        
        if self.config.SAVE_CONFUSION_MATRIX and VIZ_AVAILABLE:
            self._plot_confusion_matrix(cm)
        
        if self.config.SAVE_ROC_CURVES and VIZ_AVAILABLE:
            self._plot_roc_curves(y_test_one_hot, y_pred_proba)
        
        return results
    
    def _plot_confusion_matrix(self, cm: np.ndarray):
        try:
            plt.figure(figsize=(14, 12))
            sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                       xticklabels=self.label_encoder.classes_,
                       yticklabels=self.label_encoder.classes_)
            plt.title('Матрица ошибок классификации намерений')
            plt.xlabel('Предсказанные классы')
            plt.ylabel('Истинные классы')
            plt.xticks(rotation=45, ha='right')
            plt.yticks(rotation=0)
            plt.tight_layout()
            plt.savefig('confusion_matrix.png', dpi=300)
            plt.close()
            logger.info("Сохранена матрица ошибок: confusion_matrix.png")
        except Exception as e:
            logger.warning(f"Не удалось сохранить матрицу ошибок: {e}")
    
    def _plot_roc_curves(self, y_true_one_hot: np.ndarray, y_pred_proba: np.ndarray):
        try:
            plt.figure(figsize=(12, 8))
            
            for i, intent in enumerate(INTENTS):
                if len(np.unique(y_true_one_hot[:, i])) > 1:
                    fpr, tpr, _ = roc_curve(y_true_one_hot[:, i], y_pred_proba[:, i])
                    roc_auc = auc(fpr, tpr)
                    plt.plot(fpr, tpr, label=f'{intent} (AUC = {roc_auc:.3f})')
            
            plt.plot([0, 1], [0, 1], 'k--', label='Случайный классификатор')
            plt.xlim([0.0, 1.0])
            plt.ylim([0.0, 1.05])
            plt.xlabel('False Positive Rate')
            plt.ylabel('True Positive Rate')
            plt.title('ROC-кривые для всех классов')
            plt.legend(loc="lower right", fontsize=8)
            plt.grid(True, alpha=0.3)
            plt.tight_layout()
            plt.savefig('roc_curves.png', dpi=300)
            plt.close()
            logger.info("Сохранены ROC-кривые: roc_curves.png")
        except Exception as e:
            logger.warning(f"Не удалось сохранить ROC-кривые: {e}")

    # Сохранение модели и компонентов
    def save_model(self, path: str):
        try:
            # Создаем каталог, если его нет
            os.makedirs(path, exist_ok=True)
            # Сохраняем модель Keras
            self.model.save(os.path.join(path, 'model.h5'))

            # Сохраняем токенизатор
            with open(os.path.join(path, 'tokenizer.pkl'), 'wb') as f:
                pickle.dump(self.tokenizer, f)

            # Сохраняем метки
            with open(os.path.join(path, 'label_encoder.pkl'), 'wb') as f:
                pickle.dump(self.label_encoder, f)

            if self.cache is not None:
                with open(os.path.join(path, 'cache_stats.pkl'), 'wb') as f:
                    pickle.dump(self.cache.get_stats(), f)

            # Сохраняем конфигурацию в json
            config_data = {
                'vocab_size': self.vocab_size,
                'max_sequence_length': self.max_sequence_length,
                'embedding_size': self.embedding_size,
                'intents': INTENTS
                'use_attention': self.config.USE_ATTENTION,
                'use_gru': self.config.USE_GRU,
                'use_pretrained_embeddings': self.config.USE_PRETRAINED_EMBEDDINGS
            }

            with open(os.path.join(path, 'config.json'), 'w', encoding='utf-8') as f:
                json.dump(config_data, f, ensure_ascii=False, indent=2)

            if self.config.EXPORT_TO_ONNX and ONNX_AVAILABLE:
                self.export_to_onnx(os.path.join(path, 'model.onnx'))

            logging.info(f"model успешно сохранена в {path}")
      
      except Exception as e:
          logging.error(f"Ошибка при сохранении модели: {e}")
          raise

    def export_to_onnx(self, path: str = 'model.onnx'):
        if not ONNX_AVAILABLE:
            logger.warning("ONNX недоступен")
            return
        
        try:
            spec = (tf.TensorSpec((None, self.max_sequence_length), tf.int32, name="input"),)
            model_proto, _ = tf2onnx.convert.from_keras(self.model, input_signature=spec)
            onnx.save(model_proto, path)
            logger.info(f"Модель экспортирована в ONNX: {path}")
        except Exception as e:
            logger.error(f"Ошибка экспорта в ONNX: {e}")

    # Загрузка модели из каталога
    @classmethod
    def load_from_file(cls, path: str) -> 'PetStoreIntentClassifier':
        # Загружаем конфигурацию
        with open(os.path.join(path, 'config.json'), 'r', encoding='utf-8') as f:
            config_data = json.load(f)

        # Создаем экземпляр класса
        instance = cls()

        # Загружаем параметры
        instance.vocab_size = config_data['vocab_size']
        instance.max_sequence_length = config_data['max_sequence_length']
        instance.embedding_size = config_data['embedding_size']

        # Загружаем компоненты
        with open(os.path.join(path, 'tokenizer.pkl'), 'rb') as f:
            instance.tokenizer = pickle.load(f)

        with open(os.path.join(path, 'label_encoder.pkl'), 'rb') as f:
            instance.label_encoder = pickle.load(f)

        # Загружаем модель
        instance.model = tf.keras.models.load_model(os.path.join(path, 'model.h5'))
        return instance

    # Метод для оценки модели
    def evaluate(self, X_test: np.ndarray, y_test: np.ndarray):
        return self.model.evaluate(X_test, y_test)

    # Предскажем намерения по новому тексту
    def predict(self, text: str) -> Tuple[str, float]:
        # Преобразуем текст в последовательность
        sequence = self.tokenizer.texts_to_sequences([text])
        # Обрезка или дополнение
        X_input = pad_sequences(sequence, maxlen=self.max_sequence_length,
                              padding='post', truncating='post')
        # Предсказание
        predictions  = self.model.predict(X_input, verbose=0)[0]
        # Определение класса с наибольшей вероятностью
        pred_class = np.argmax(predictions)
        confidence  = predictions[pred_class]
        # Обратное преобразование метки
        intent  = self.label_encoder.inverse_transform([pred_class])[0]
        return intent, float(confidence)

   def predict_batch(self, texts: List[str]) -> List[Tuple[str, float]]:  
        clean_texts = [self._preprocess_text(t) for t in texts]
        sequences = self.tokenizer.texts_to_sequences(clean_texts)
        X_input = pad_sequences(sequences, maxlen=self.max_sequence_length,
                           padding='post', truncating='post')
    
        all_predictions = self.model.predict(X_input, verbose=0)
        results = []
    
        for predictions in all_predictions:
            pred_class = np.argmax(predictions)
            confidence = predictions[pred_class]
            intent = self.label_encoder.inverse_transform([pred_class])[0]
            results.append((intent, float(confidence)))
    
        return results
            
    
