# Модуль для обучения нейросетевой модели классификации запросов пользователей,обучается на данных с сайта 4lapy.ru для определения намерений пользователя

import json
import numpy as np
import tensorflow as tf
from tensorflow.keras import layers, models
from tensorflow.keras.preprocessing.text import Tokenizer
from tensorflow.keras.preprocessing.sequence import pad_sequences
from sklearn.preprocessing import LabelEncoder
from typing import List, Tuple, Dict
from sklearn.model_selection import train_test_split
import pickle
import os
import logging

# Настройка логирования для отслеживания процессов
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# Конфигурационный класс для гиперпараметров модели
class Config:
    VOCAB_SIZE = 10000  # Максимальный размер словаря
    MAX_SEQUENCE_LENGTH = 100  # Максимальная длина входной последовательности
    EMBEDDING_SIZE = 128  # Размерность векторных представлений слов
    BATCH_SIZE = 32  # Размер батча для обучения
    EPOCHS = 50  # Количество эпох обучения
    VALIDATION_SPLIT = 0.2  # Доля данных для валидации

# Определение намерений пользователя для классификации
INTENTS = [
    "find_product",           # Поиск товара
    "get_product_info",       # Получение информации о товаре
    "check_price",            # Проверка цены
    "check_availability",     # Проверка наличия
    "get_care_advice",        # Советы по уходу за питомцем
    "ask_delivery",           # Вопросы о доставке
    "ask_payment",            # Вопросы об оплате
    "ask_promotions",         # Вопросы об акциях
    "greeting",               # Приветствие
    "goodbye",                # Прощание
    "help",                   # Помощь
    "other"                   # Прочие запросы
]

# Классификатор пользовательских намерений для запросов, связанных с зоомагазином
# Используем в работе рекуррентную нейронную сеть (RNN) с слоями LSTM
class PetStoreIntentClassifier:

    # Инициализация классификатора  
    def __init__(self, config=Config):
        self.vocab_size = config.VOCAB_SIZE
        self.max_sequence_length = config.MAX_SEQUENCE_LENGTH
        self.embedding_size = config.EMBEDDING_SIZE
        self.batch_size = config.BATCH_SIZE
        self.epochs = config.EPOCHS
        self.validation_split = config.VALIDATION_SPLIT

        
        # Инициализация компонентов предобработки текста и меток
        self.tokenizer = Tokenizer(num_words=self.vocab_size, oov_token="<OOV>")
        self.label_encoder = LabelEncoder()
        self.model = None

    # Подготовим данные для обучения: токенизация и кодирование меток   
    def prepare_data(self, texts: List[str], labels: List[str]) -> Tuple[np.ndarray, np.ndarray]:
        
        # Обучение токенизатора на всех текстах
        self.tokenizer.fit_on_texts(texts)
        # Преобразование текстов в последовательности чисел
        sequences = self.tokenizer.texts_to_sequences(texts)
        # Обрезка или дополнение последовательностей до max_sequence_length
        X = pad_sequences(sequences, maxlen=self.max_sequence_length, 
                                         padding='post', truncating='post')
        
        # Кодирование меток в числа
        y = self.label_encoder.fit_transform(labels)
        
        return X, y
    
    # Создадим архитектуры нейросети
    def build_model(self) -> tf.keras.Model:

        model = models.Sequential([ 
            # Создаем последовательную модель
            # Встроенный слой для превращения слов в плотные векторные представления
            layers.Embedding(self.vocab_size, self.embedding_size, input_length=self.max_sequence_length),
            # Двунаправленный слой LSTM для обработки последовательностей
            layers.Bidirectional(layers.LSTM(64, return_sequences=True)),
            # Регуляризация Dropout
            layers.Dropout(0.3),
            # Еще один слой LSTM
            layers.Bidirectional(layers.LSTM(32)),
            # Еще Dropout
            layers.Dropout(0.3),
            # Полносвязный слой перед выходом
            layers.Dense(64, activation='relu'),
            layers.Dropout(0.2),
            # Выходной слой с количеством нейронов равным числу классов
            layers.Dense(len(INTENTS), activation='softmax')
        ])
        # Компиляция модели с оптимизатором и функцией потерь
        model.compile(
            optimizer='adam',
            loss='sparse_categorical_crossentropy',
            metrics=['accuracy']
        )
        self.model = model
        return model
    
    # Обучим модель
    def train(self, X: np.ndarray, y: np.ndarray, X_test: np.ndarray = None, y_test: np.ndarray = None):
        # Если модель еще не создана, создаем
        if self.model is None:
            self.build_model()

        # Настройка callback для ранней остановки обучения
        early_stop = tf.keras.callbacks.EarlyStopping(
            monitor='val_loss',
            patience=5,
            restore_best_weights=True
        )
        # Обучение с использованием тестового набора или validation split
        if X_test is not None and y_test is not None:
            # Обучение с отдельным тестовым набором
            history = self.model.fit(
            X, y,
            epochs=self.epochs,
            batch_size=self.batch_size,
            validation_data=(X_test, y_test),
            callbacks=[early_stop],
            verbose=1
         )
        else:
            # Обучение с использованием validation_split
            history = self.model.fit(
                X, y,
                epochs=self.epochs,
                batch_size=self.batch_size,
                validation_split=self.validation_split,
                callbacks=[early_stop],
                verbose=1
             )
        return history

    # Сохранение модели и компонентов
    def save_model(self, path: str):
        try:
            # Создаем каталог, если его нет
            os.makedirs(path, exist_ok=True)
            # Сохраняем модель Keras
            self.model.save(os.path.join(path, 'model.h5'))

            # Сохраняем токенизатор
            with open(os.path.join(path, 'tokenizer.pkl'), 'wb') as f:
            pickle.dump(self.tokenizer, f)

            # Сохраняем метки
            with open(os.path.join(path, 'label_encoder.pkl'), 'wb') as f:
            pickle.dump(self.label_encoder, f)

            # Сохраняем конфигурацию в json
            config_data = {
                'vocab_size': self.vocab_size,
                'max_sequence_length': self.max_sequence_length,
                'embedding_size': self.embedding_size,
                'intents': INTENTS
            }

            with open(os.path.join(path, 'config.json'), 'w', encoding='utf-8') as f:
            json.dump(config_data, f, ensure_ascii=False, indent=2)

            logging.info(f"model успешно сохранена в {path}")
      
      except Exception as e:
          logging.error(f"Ошибка при сохранении модели: {e}")
          raise

    # Загрузка модели из каталога
    @classmethod
    def load_from_file(cls, path: str) -> 'PetStoreIntentClassifier':
        # Загружаем конфигурацию
        with open(os.path.join(path, 'config.json'), 'r', encoding='utf-8') as f:
            config_data = json.load(f)

        # Создаем экземпляр класса
        instance = cls()

        # Загружаем параметры
        instance.vocab_size = config_data['vocab_size']
        instance.max_sequence_length = config_data['max_sequence_length']
        instance.embedding_size = config_data['embedding_size']

        # Загружаем компоненты
        with open(os.path.join(path, 'tokenizer.pkl'), 'rb') as f:
            instance.tokenizer = pickle.load(f)

        with open(os.path.join(path, 'label_encoder.pkl'), 'rb') as f:
            instance.label_encoder = pickle.load(f)

        # Загружаем модель
        instance.model = tf.keras.models.load_model(os.path.join(path, 'model.h5'))
        return instance

    # Метод для оценки модели
    def evaluate(self, X_test: np.ndarray, y_test: np.ndarray):
        return self.model.evaluate(X_test, y_test)

    # Предскажем намерения по новому тексту
    def predict(self, text: str) -> Tuple[str, float]:
        # Преобразуем текст в последовательность
        sequence = self.tokenizer.texts_to_sequences([text])
        # Обрезка или дополнение
        X_input = pad_sequences(sequence, maxlen=self.max_sequence_length,
                              padding='post', truncating='post')
        # Предсказание
        predictions  = self.model.predict(X_input, verbose=0)[0]
        # Определение класса с наибольшей вероятностью
        pred_class = np.argmax(predictions)
        confidence  = predictions[pred_class]
        # Обратное преобразование метки
        intent  = self.label_encoder.inverse_transform([pred_class])[0]
        return intent, float(confidence)
    
