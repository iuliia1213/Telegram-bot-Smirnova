# Обертка для API (для интеграции с внешним сервисом)
class RESTAPIWrapper:
    def __init__(self, model_path: str):
        self.model = PetStoreIntentClassifier.load_from_file(model_path)
        self.start_time = datetime.now()
        self.request_count = 0
    # Предсказание через API с порогом доверия
    def predict_api(self, text: str, threshold: float = 0.6) -> Dict:
        self.request_count += 1
        intent, confidence, is_confident = self.model.predict_with_confidence_threshold(text, threshold)
        
        return {
            'text': text,
            'intent': intent,
            'confidence': confidence,
            'is_confident': is_confident,
            'threshold_used': threshold,
            'available_intents': INTENTS,
            'stats': {
                'total_requests': self.request_count,
                'cache_hit_rate': self.model.get_cache_stats().get('hit_rate', 0),
                'uptime_seconds': (datetime.now() - self.start_time).seconds
            }
        }
    # Многократное предсказание
    def batch_predict_api(self, texts: List[str]) -> List[Dict]:
        results = []
        for text in texts:
            results.append(self.predict_api(text))
        return results
    # Проверка состояния сервиса
    def health_check(self) -> Dict:
        return {
            'status': 'healthy',
            'model_loaded': True,
            'timestamp': datetime.now().isoformat(),
            'available_intents': len(INTENTS),
            'cache_stats': self.model.get_cache_stats()
        }

