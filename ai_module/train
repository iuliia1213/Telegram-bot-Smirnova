# Классификатор пользовательских намерений для запросов, связанных с зоомагазином
# Используем в работе рекуррентную нейронную сеть (RNN) с слоями LSTM
class PetStoreIntentClassifier:

    # Инициализация классификатора  
    def __init__(self, vocab_size: int = 10000, max_sequence_length: int = 100,
                 embedding_size: int = 128):
        
        self.vocab_size = vocab_size
        self.max_sequence_length = max_sequence_length
        self.embedding_size = embedding_size
        
        # Инициализация компонентов предобработки текста
        self.tokenizer = Tokenizer(num_words=vocab_size, oov_token="<OOV>")
        self.label_encoder = LabelEncoder()
        self.model = None

    # Подготовим данные для обучения: токенизация и кодирование меток   
    def подготовить_данные(self, тексты: List[str], метки: List[str]) -> Tuple[np.ndarray, np.ndarray]:
        
        # Обучение токенизатора на всех текстах
        self.tokenizer.fit_on_texts(тексты)
        последовательности = self.tokenizer.texts_to_sequences(тексты)
        отформатированные_последовательности = pad_sequences(последовательности, maxlen=self.max_sequence_length, 
                                         padding='post', truncating='post')
        
        # Кодирование меток в числа
        закодированные_метки = self.label_encoder.fit_transform(метки)
        
        return отформатированные_последовательности, закодированные_метки
    
    # Создадим архитектуры нейросети
    def построить_модель(self) -> tf.keras.Model:

        модель = models.Sequential([
            layers.Embedding(self.vocab_size, self.embedding_size, input_length=self.max_sequence_length),
            layers.Bidirectional(layers.LSTM(64, return_sequences=True)),
            layers.Dropout(0.3),
            layers.Bidirectional(layers.LSTM(32)),
            layers.Dropout(0.3),
            layers.Dense(64, activation='relu'),
            layers.Dropout(0.2),
            layers.Dense(len(INTENTS), activation='softmax')
        ])
        модель.compile(
            optimizer='adam',
            loss='sparse_categorical_crossentropy',
            metrics=['accuracy']
        )
        self.model = модель
        return модель
    
    # Обучим модель 
    def обучить(self, X_train: np.ndarray, y_train: np.ndarray, 
                epochs: int = 20, batch_size: int = 32,
                validation_split: float = 0.2) -> tf.keras.callbacks.History:
       
        if self.model is None:
            self.построить_модель()
        
        ранняя_остановка = tf.keras.callbacks.EarlyStopping(
            monitor='val_loss',
            patience=5,
            restore_best_weights=True
        )
        история = self.model.fit(
            X_train, y_train,
            epochs=epochs,
            batch_size=batch_size,
            validation_split=validation_split,
            callbacks=[ранняя_остановка],
            verbose=1
        )
        return история
    
    # Предскажем намерения по новому тексту
    def предсказать(self, текст: str) -> Tuple[str, float]:
        
        последовательность = self.tokenizer.texts_to_sequences([текст])
        отформатированный_вход = pad_sequences(последовательность, maxlen=self.max_sequence_length,
                              padding='post', truncating='post')
        прогнозы = self.model.predict(отформатированный_вход, verbose=0)[0]
        класс_предсказания = np.argmax(прогнозы)
        уверенность = прогнозы[класс_предсказания]
        намерение = self.label_encoder.inverse_transform([класс_предсказания])[0]
        return намерение, float(уверенность)
    
    # Сохранение модели и компонентов
    def сохранить_модель(self, путь: str):
        
        os.makedirs(путь, exist_ok=True)
        self.model.save(os.path.join(путь, 'model.h5'))
        with open(os.path.join(путь, 'tokenizer.pkl'), 'wb') as f:
            pickle.dump(self.tokenizer, f)
        with open(os.path.join(путь, 'label_encoder.pkl'), 'wb') as f:
            pickle.dump(self.label_encoder, f)
        конфиг = {
            'vocab_size': self.vocab_size,
            'max_sequence_length': self.max_sequence_length,
            'embedding_size': self.embedding_size,
            'intents': INTENTS
        }
        with open(os.path.join(путь, 'config.json'), 'w', encoding='utf-8') as f:
            json.dump(конфиг, f, ensure_ascii=False, indent=2)
    
    @classmethod
    # Загрузим модели из файла
    def загрузить_модель(cls, путь: str) -> 'PetStoreIntentClassifier':

        with open(os.path.join(путь, 'config.json'), 'r', encoding='utf-8') as f:
            конфиг = json.load(f)

        # Создаем новый экземпляр
        классификатор = cls(
            vocab_size=конфиг['vocab_size'],
            max_sequence_length=конфиг['max_sequence_length'],
            embedding_size=конфиг['embedding_size']
        )

        # Загружаем компоненты
        with open(os.path.join(путь, 'tokenizer.pkl'), 'rb') as f:
            классификатор.tokenizer = pickle.load(f)
        with open(os.path.join(путь, 'label_encoder.pkl'), 'rb') as f:
            классификатор.label_encoder = pickle.load(f)

        # Загружаем модель
        классификатор.model = tf.keras.models.load_model(os.path.join(путь, 'model.h5'))
        return классификатор

