# Модуль middleware для логирования всех входящих событий. Логирует текстовые сообщения и callback-запросы.
import logging
from typing import Callable, Dict, Any, Awaitable
from aiogram import BaseMiddleware
from aiogram.types import Message, CallbackQuery

# Создаём логгер для этого модуля
logger = logging.getLogger(__name__)

class LoggingMiddleware(BaseMiddleware):
    # Middleware-класс для логирования всех сообщений
    
    async def __call__(
        self,
        handler: Callable[[Message, Dict[str, Any]], Awaitable[Any]],
        event: Message,
        data: Dict[str, Any]
    ) -> Any:
        """
        Вызывается диспетчером при каждом входящем событии.
        
        Аргументы:
            handler: Следующий обработчик в цепочке
            event: Входящее событие (сообщение или callback-запрос)
            data: Дополнительные данные (состояние FSM, raw_update и т.д.)
        
        Возвращает:
            Результат выполнения следующего обработчика
        """
        # Определяем тип события и логируем его
        if isinstance(event, Message):
            # Это текстовое сообщение
            polzovatel_id = event.from_user.id if event.from_user else "Неизвестно"
            imya_polzovatelya = event.from_user.username if event.from_user else "Без username"
            
            logger.info(
                f"Пользователь: {polzovatel_id} (@{imya_polzovatelya}) | "
                f"Текст: «{event.text or '<пусто>'}»"
            )
            
        elif isinstance(event, CallbackQuery):
            # Это нажатие на инлайн-кнопку
            polzovatel_id = event.from_user.id if event.from_user else "Неизвестно"
            
            logger.info(
                f"🔘 CALLBACK | "
                f"Пользователь: {polzovatel_id} | "
                f"Данные: {event.data}"
            )
        
        else:
            # Другой тип события 
            logger.debug(f"📎 Другое событие: {type(event).__name__}")
        
        # Передаём управление следующему обработчику в цепочке
        return await handler(event, data)

def zaregistrirovat_vse_middleware(dispetcher):
    """
    Подключает все middleware к диспетчеру.
    Вызывается один раз при инициализации бота.
    
    Аргументы:
        dispetcher: Экземпляр aiogram.Dispatcher
    """
    
    # Создаём экземпляр middleware
    middleware_logirovaniya = LoggingMiddleware()
    
    # Подключаем к обработке сообщений
    dispetcher.message.middleware(middleware_logirovaniya)
    
    # Подключаем к обработке callback-запросов
    dispetcher.callback_query.middleware(middleware_logirovaniya)
    
    logger.info("✅ Middleware для логирования успешно зарегистрированы")
