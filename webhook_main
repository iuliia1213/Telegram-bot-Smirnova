
import os
import sys
import asyncio
from pathlib import Path

# Добавляем корневую директорию в путь для импортов
sys.path.append(str(Path(__file__).parent))

from aiogram import Bot, Dispatcher, types
from aiogram.client.default import DefaultBotProperties
from aiogram.enums import ParseMode
from aiogram.fsm.storage.memory import MemoryStorage
from aiohttp import web

# Импортируем модули
from database.engine import init_db, close_db
from handlers import register_all_handlers

# Конфигурация 
BOT_TOKEN = os.getenv("BOT_TOKEN")
if not BOT_TOKEN:
    raise ValueError("BOT_TOKEN не задан в переменных окружения")


RENDER_EXTERNAL_HOSTNAME = os.getenv("RENDER_EXTERNAL_HOSTNAME")
if not RENDER_EXTERNAL_HOSTNAME:
    raise ValueError("RENDER_EXTERNAL_HOSTNAME не задан. Добавьте эту переменную в Render Dashboard.")
WEBHOOK_URL = f"https://{RENDER_EXTERNAL_HOSTNAME}/webhook"

# Инициализация бота и диспетчера
bot = Bot(token=BOT_TOKEN, default=DefaultBotProperties(parse_mode=ParseMode.HTML))
storage = MemoryStorage()
dp = Dispatcher(storage=storage)

# Регистрируем все  обработчики (из commands.py, admin.py и т.д.)
register_all_handlers(dp)


# Обработчик вебхука 
async def handle_webhook(request: web.Request) -> web.Response:
    
    # Принимает обновление от Telegram и передает его диспетчеру.
    
    try:
        update_data = await request.json()
        update = types.Update(**update_data)
        await dp.feed_update(bot, update)
        return web.Response(status=200)
    except Exception as e:
        print(f"Ошибка обработки вебхука: {e}")
        # Всегда возвращаем 200, чтобы Telegram не повторял неудачные запросы
        return web.Response(status=200)


# Функции запуска и остановки 
async def on_startup():
    # Выполняется при запуске веб-сервера
    print("Инициализация базы данных...")
    await init_db()
    
    print(f"Установка вебхука на {WEBHOOK_URL}")
    await bot.set_webhook(WEBHOOK_URL, drop_pending_updates=True)
    
    # Проверка статуса
    webhook_info = await bot.get_webhook_info()
    print(f"Статус вебхука: {webhook_info}")
    print("Бот успешно запущен и ожидает сообщения!")


async def on_shutdown():
    # Выполняется при остановке веб-сервера
    print("Удаление вебхука...")
    await bot.delete_webhook()
    await close_db()
    await bot.session.close()
    print("Бот остановлен.")


# Запуск aiohttp веб-сервера 
def main():
    app = web.Application()
    app.router.add_post('/webhook', handle_webhook)
    
    # Регистрируем функции запуска и остановки
    app.on_startup.append(lambda _: on_startup())
    app.on_shutdown.append(lambda _: on_shutdown())
    
    port = int(os.environ.get('PORT', 8080))
    print(f"Запуск веб-сервера на порту {port}")
    
    web.run_app(app, host='0.0.0.0', port=port)


if __name__ == '__main__':
    main()
